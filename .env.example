# Copy to .env.local for local dev, and add the same keys in Vercel → Project → Settings → Environment Variables

# Required — get a free key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Where contact form messages are delivered
CONTACT_TO_EMAIL=dhruvalabroad@gmail.com

# Optional: after you verify your domain in Resend, switch FROM to something like:
# RESEND_FROM_EMAIL=Portfolio <hello@yourdomain.com>
# Until then, onboarding@resend.dev only delivers to the email on your Resend account.
RESEND_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>
